<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Will you marry me?</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600;700&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg-1:#fff1f4;
    --bg-2:#ffd9e3;
    --rose:#e84773;
    --rose-dark:#c8345d;
    --wine:#7a2540;
    --gold:#dba43a;
    --white:#ffffff;
  }

  *{box-sizing:border-box;}

  html,body{
    margin:0;
    padding:0;
    width:100%;
    height:100%;
    overflow:hidden;
    font-family:'Quicksand',sans-serif;
    background:linear-gradient(160deg,var(--bg-1) 0%,var(--bg-2) 100%);
    color:var(--wine);
  }

  /* ambient floating hearts */
  .hearts{
    position:fixed;
    inset:0;
    pointer-events:none;
    z-index:1;
    overflow:hidden;
  }
  .heart{
    position:absolute;
    bottom:-40px;
    color:rgba(232,71,115,0.35);
    font-size:1.4rem;
    animation:floatUp linear infinite;
    will-change:transform;
  }
  @keyframes floatUp{
    0%{ transform:translateY(0) rotate(0deg); opacity:0; }
    10%{ opacity:0.8; }
    90%{ opacity:0.6; }
    100%{ transform:translateY(-110vh) rotate(360deg); opacity:0; }
  }

  @media (prefers-reduced-motion: reduce){
    .heart{ animation:none; display:none; }
  }

  .stage{
    position:relative;
    width:100%;
    height:100%;
    display:flex;
    align-items:center;
    justify-content:center;
    z-index:2;
  }

  /* --- Proposal card --- */
  .proposal-card{
    text-align:center;
    padding:48px 36px;
    max-width:540px;
    transition:opacity .4s ease, transform .4s ease;
  }
  .proposal-card.hidden{
    opacity:0;
    transform:scale(0.92);
    pointer-events:none;
    position:absolute;
  }

  .ring-icon{
    width:54px;
    height:54px;
    margin:0 auto 18px;
    display:block;
  }

  .eyebrow{
    letter-spacing:0.18em;
    text-transform:uppercase;
    font-size:0.72rem;
    font-weight:700;
    color:var(--rose-dark);
    margin-bottom:14px;
  }

  h1{
    font-family:'Dancing Script',cursive;
    font-weight:700;
    font-size:clamp(2.6rem, 8vw, 4.2rem);
    margin:0 0 10px;
    color:var(--wine);
    line-height:1.1;
  }

  .subtitle{
    font-size:1rem;
    font-weight:500;
    color:var(--rose-dark);
    margin:0 0 8px;
    min-height:1.4em;
    transition:opacity .2s ease;
  }

  .button-row{
    margin-top:34px;
    display:flex;
    gap:22px;
    justify-content:center;
    align-items:center;
    position:relative;
    min-height:70px;
  }

  button{
    font-family:'Quicksand',sans-serif;
    font-weight:700;
    border:none;
    cursor:pointer;
    border-radius:999px;
    transition:transform .25s ease, box-shadow .25s ease, left .35s ease, top .35s ease, font-size .25s ease, padding .25s ease;
  }

  .btn-yes{
    background:var(--rose);
    color:var(--white);
    font-size:1.05rem;
    padding:16px 38px;
    box-shadow:0 10px 24px rgba(232,71,115,0.35);
  }
  .btn-yes:hover{
    transform:translateY(-2px) scale(1.03);
    box-shadow:0 14px 28px rgba(232,71,115,0.45);
  }

  .btn-no{
    background:var(--white);
    color:var(--wine);
    font-size:1.05rem;
    padding:16px 38px;
    box-shadow:0 6px 16px rgba(122,37,64,0.12);
    position:relative;
  }
  .btn-no.dodging{
    position:fixed;
    z-index:5;
  }

  /* --- Celebration / popup --- */
  .celebration{
    text-align:center;
    padding:54px 40px;
    max-width:560px;
    opacity:0;
    transform:scale(0.85);
    transition:opacity .5s ease, transform .5s cubic-bezier(.34,1.56,.64,1);
    pointer-events:none;
    position:absolute;
  }
  .celebration.show{
    opacity:1;
    transform:scale(1);
    pointer-events:auto;
    position:relative;
  }

  .celebration .ring-icon{
    width:64px;
    height:64px;
  }

  .celebration h2{
    font-family:'Dancing Script',cursive;
    font-weight:700;
    font-size:clamp(2.2rem, 7vw, 3.4rem);
    color:var(--rose-dark);
    margin:6px 0 14px;
  }

  .celebration p{
    font-size:1.05rem;
    font-weight:600;
    color:var(--wine);
    margin:0;
    line-height:1.6;
  }

  .pulse{
    display:inline-block;
    animation:pulse 1.4s ease-in-out infinite;
  }
  @keyframes pulse{
    0%,100%{ transform:scale(1); }
    50%{ transform:scale(1.18); }
  }

  @media (max-width:480px){
    .button-row{ gap:16px; }
    button{ padding:14px 28px; font-size:0.95rem; }
  }
</style>
</head>
<body>

<div class="hearts" id="hearts"></div>

<div class="stage">

  <div class="proposal-card" id="proposalCard">
    <svg class="ring-icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="32" cy="38" r="16" stroke="#dba43a" stroke-width="3"/>
      <path d="M32 22 L24 10 H40 L32 22Z" fill="#dba43a"/>
      <path d="M27 13 L32 22 L37 13" stroke="#fff8ec" stroke-width="1.2" fill="none"/>
    </svg>
    <div class="eyebrow">Yamini, unaku oru kelvi</div>
    <h1>Will you marry me?</h1>
    <p class="subtitle" id="caption">Take your time… but the answer is right there 👉</p>

    <div class="button-row">
      <button class="btn-yes" id="yesBtn">Yes</button>
      <button class="btn-no" id="noBtn">No</button>
    </div>
  </div>

  <div class="celebration" id="celebration">
    <svg class="ring-icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="32" cy="38" r="18" stroke="#dba43a" stroke-width="3.5"/>
      <path d="M32 20 L22 6 H42 L32 20Z" fill="#dba43a"/>
      <path d="M26 9 L32 20 L38 9" stroke="#fff8ec" stroke-width="1.4" fill="none"/>
    </svg>
    <h2>I knew you'd say yes <span class="pulse">💕</span></h2>
    <p>I love you, today and every day until my last breath<br>and I am sorry for all what I did.</p>
  </div>

</div>

<script>
  // ---- ambient floating hearts ----
  const heartsContainer = document.getElementById('hearts');
  const heartSymbols = ['💗','💕','💖','♡'];
  const heartCount = 22;
  for(let i=0;i<heartCount;i++){
    const h = document.createElement('span');
    h.className = 'heart';
    h.textContent = heartSymbols[Math.floor(Math.random()*heartSymbols.length)];
    h.style.left = Math.random()*100 + 'vw';
    h.style.fontSize = (1 + Math.random()*1.6) + 'rem';
    h.style.animationDuration = (8 + Math.random()*10) + 's';
    h.style.animationDelay = (Math.random()*10) + 's';
    heartsContainer.appendChild(h);
  }

  // ---- dodging "No" button ----
  const noBtn = document.getElementById('noBtn');
  const yesBtn = document.getElementById('yesBtn');
  const caption = document.getElementById('caption');

  const captions = [
    "Are you sure? 👀",
    "Nice try 😏",
    "That one doesn't work anymore",
    "Try again 😉",
    "Almost… not quite",
    "I don't think so 😌",
    "You really can't catch it now",
    "The other button is right there 💕",
    "Getting warmer for YES",
    "Just say yes already 🥹",
    "The universe is rooting for YES",
    "Running out of corners 😅",
    "YES is literally right there →",
    "Let love win 💖",
    "Okay but really… YES?"
  ];
  let dodgeCount = 0;

  function moveNoButton(){
    if(!noBtn.classList.contains('dodging')){
      noBtn.classList.add('dodging');
    }
    const rect = noBtn.getBoundingClientRect();
    const margin = 20;
    const maxX = Math.max(margin, window.innerWidth - rect.width - margin);
    const maxY = Math.max(margin, window.innerHeight - rect.height - margin);

    let newX, newY, tries = 0;
    do{
      newX = margin + Math.random()*(maxX-margin);
      newY = margin + Math.random()*(maxY-margin);
      tries++;
    } while(tries < 6 && Math.abs(newX-rect.left) < 80 && Math.abs(newY-rect.top) < 80);

    noBtn.style.left = newX + 'px';
    noBtn.style.top = newY + 'px';

    dodgeCount++;
    caption.style.opacity = 0;
    setTimeout(()=>{
      caption.textContent = captions[(dodgeCount-1) % captions.length];
      caption.style.opacity = 1;
    }, 150);

    const growth = Math.min(1 + dodgeCount*0.06, 1.7);
    yesBtn.style.transform = `scale(${growth})`;
  }

  noBtn.addEventListener('pointerenter', moveNoButton);
  noBtn.addEventListener('focus', moveNoButton);
  noBtn.addEventListener('touchstart', function(e){
    e.preventDefault();
    moveNoButton();
  }, {passive:false});
  // safety net: if it's ever somehow clicked, dodge instead of "succeeding"
  noBtn.addEventListener('click', function(e){
    e.preventDefault();
    moveNoButton();
  });

  // ---- Yes click -> celebration ----
  const proposalCard = document.getElementById('proposalCard');
  const celebration = document.getElementById('celebration');

  yesBtn.addEventListener('click', function(){
    proposalCard.classList.add('hidden');
    celebration.classList.add('show');
  });

  window.addEventListener('resize', function(){
    if(noBtn.classList.contains('dodging')){
      const rect = noBtn.getBoundingClientRect();
      const maxX = Math.max(20, window.innerWidth - rect.width - 20);
      const maxY = Math.max(20, window.innerHeight - rect.height - 20);
      noBtn.style.left = Math.min(rect.left, maxX) + 'px';
      noBtn.style.top = Math.min(rect.top, maxY) + 'px';
    }
  });
</script>

</body>
</html>
